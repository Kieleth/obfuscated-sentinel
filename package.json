{
  "name": "obfuscated-sentinel",
  "version": "2.0.0",
  "description": "Research on adversarial code and LLM deobfuscation. Umbrella repo for multiple papers.",
  "private": false,
  "scripts": {
    "test": "cd papers/poisoned-identifiers && node ../../scripts/test-scorer.js",
    "preflight": "cd papers/poisoned-identifiers && node ../../scripts/preflight.js",
    "poisoned:phase0": "cd papers/poisoned-identifiers && node ../../scripts/run-experiment.js --batch experiments/testbed/phase0-replication.json --output experiments/results/phase0",
    "poisoned:phase1": "cd papers/poisoned-identifiers && node ../../scripts/run-experiment.js --batch experiments/testbed/phase1-string-trust.json --output experiments/results/phase1",
    "poisoned:phase2": "cd papers/poisoned-identifiers && node ../../scripts/run-experiment.js --batch experiments/testbed/phase2-streisand.json --output experiments/results/phase2",
    "poisoned:phase3": "cd papers/poisoned-identifiers && node ../../scripts/run-experiment.js --batch experiments/testbed/phase3-extended.json --output experiments/results/phase3",
    "poisoned:phase4": "cd papers/poisoned-identifiers && node ../../scripts/run-experiment.js --batch experiments/testbed/phase4-mechanism.json --output experiments/results/phase4",
    "poisoned:phase5": "cd papers/poisoned-identifiers && node ../../scripts/run-experiment.js --batch experiments/testbed/phase5-nboost.json --output experiments/results/phase5",
    "poisoned:phase6": "cd papers/poisoned-identifiers && node ../../scripts/run-experiment.js --batch experiments/testbed/phase6-n2-boost.json --output experiments/results/phase6",
    "poisoned:phase7": "cd papers/poisoned-identifiers && node ../../scripts/run-experiment.js --batch experiments/testbed/phase7-matched-controls.json --output experiments/results/phase7",
    "poisoned:phase8": "cd papers/poisoned-identifiers && node ../../scripts/run-experiment.js --batch experiments/testbed/phase8-matched-table.json --output experiments/results/phase8",
    "poisoned:phase9": "cd papers/poisoned-identifiers && node ../../scripts/run-experiment.js --batch experiments/testbed/phase9-second-artifact.json --output experiments/results/phase9",
    "poisoned:all": "npm run poisoned:phase0 && npm run poisoned:phase1 && npm run poisoned:phase2 && npm run poisoned:phase3 && npm run poisoned:phase4 && npm run poisoned:phase5 && npm run poisoned:phase6 && npm run poisoned:phase7 && npm run poisoned:phase8 && npm run poisoned:phase9",
    "prose:run": "cd papers/prose-as-attack-surface && node ../../scripts/run-experiment.js --batch experiments/testbed/phase9-prose-trojan.json --output experiments/results"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0"
  },
  "license": "MIT"
}
